# Example environment file. Copy to `.env` for local use and fill in real values.
# `.env` is gitignored (see .gitignore) — never commit real secrets.

# Used by scripts/translate.mjs to AI-generate translations (authoring time only;
# not needed to build or serve the site).
ANTHROPIC_API_KEY=

# Used by the /api/suggest-edit serverless function to open GitHub Issues for
# reader edit suggestions. In production this is set in the Vercel project's
# Environment Variables — do NOT put a real token in the repo. A fine-grained
# personal access token scoped to the GITHUB_REPO below, with
# "Issues: Read and write" permission, is sufficient.
# For local testing of the function, run `vercel dev` with this set in .env.
GITHUB_TOKEN=

# Target GitHub repository for edit-suggestion issues, in "owner/repo" form.
# Set this in Vercel. The function falls back to this value if the var is unset,
# so a future repo move is just a config change here / in Vercel — not a code edit.
GITHUB_REPO=freefreeforum/free-wiki
